# The gateway's own API key. The Discord bot sends this in the X-API-Key header.
API_KEY=

# API bind (defaults shown)
API_HOST=0.0.0.0
API_PORT=8000

# Downstream worker: torrent-downloader. In Docker, host is the service name on
# the shared compose network (e.g. http://torrent-downloader:8000).
TORRENT_DOWNLOADER_URL=http://torrent-downloader:8000
TORRENT_DOWNLOADER_API_KEY=

# Downstream worker: medialab-jellyfin.
MEDIALAB_JELLYFIN_URL=http://medialab-jellyfin:8000
MEDIALAB_JELLYFIN_API_KEY=

# In-container path of the host media dir bind-mounted into this container.
# Used to compute TV-rename source/dest. The downloaded folder is
# MEDIA_MOUNT_PATH/<media-type-subdir>/<release_name>.
MEDIA_MOUNT_PATH=/media

# SQLite job-store file. Lives on a mounted volume so jobs survive restarts.
DB_PATH=./data/orchestrator.db
